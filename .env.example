APP_NAME=FAQ Generator API
APP_VERSION=1.0.0
ALLOWED_ORIGINS=*
WEBHOOK_SECRET=change-me

OPENAI_API_KEY=

LARK_APP_ID=
LARK_APP_SECRET=
LARK_BASE_APP_TOKEN=
LARK_FAQ_TABLE_ID=
LARK_FEEDBACK_TABLE_ID=
LARK_SOURCE_DOC_TABLE_ID=

# Zeabur 권장: /app/chroma_db (Volume 마운트)
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL_NAME=text-embedding-3-small
CACHE_TTL_SECONDS=300

# FAQ 벡터 자동 동기화
AUTO_SYNC_ENABLED=true
AUTO_SYNC_INCREMENTAL_MINUTES=10
AUTO_SYNC_FULL_HOUR=3
